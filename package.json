{
  "name": "clawui",
  "version": "0.1.0",
  "description": "ClawUI - OpenClaw Desktop Application",
  "type": "module",
  "main": "out/main/index.js",
  "homepage": "https://github.com/SttFang/ClawUI",
  "author": {
    "name": "ClawUI Team"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "sync-docs": "./scripts/sync-docs.sh"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.79",
    "@clawui/claw-sse": "workspace:*",
    "@clawui/ui": "workspace:*",
    "@electron-toolkit/utils": "^4.0.0",
    "@lobehub/icons": "^4.4.1",
    "@streamdown/cjk": "^1.0.1",
    "@streamdown/code": "^1.0.1",
    "@streamdown/math": "^1.0.1",
    "@streamdown/mermaid": "^1.0.1",
    "ai": "^6.0.77",
    "better-auth": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "i18next": "^25.8.4",
    "json5": "^2.2.3",
    "katex": "^0.16.28",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.0.2",
    "recharts": "^3.7.0",
    "shiki": "3.22.0",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.3",
    "ws": "^8.19.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@lobehub/lint": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.14.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tar": "^7.5.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
