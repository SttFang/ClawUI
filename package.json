{
  "name": "clawui",
  "version": "0.1.0",
  "description": "ClawUI - OpenClaw Desktop Application",
  "homepage": "https://github.com/SttFang/ClawUI",
  "license": "MIT",
  "author": {
    "name": "ClawUI Team"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "dev": "electron-vite dev",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "preview": "electron-vite preview",
    "sessions:reindex": "node scripts/dev/reindex-sessions.mjs",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "sync-docs": "./scripts/sync-docs.sh",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.79",
    "@clawui/openclaw-chat-stream": "workspace:*",
    "@clawui/types": "workspace:*",
    "@clawui/ui": "workspace:*",
    "@dagrejs/dagre": "^2.0.4",
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify/icons-logos": "^1.2.36",
    "@iconify/react": "^6.0.2",
    "@lobehub/icons": "^4.4.1",
    "@streamdown/cjk": "^1.0.1",
    "@streamdown/code": "^1.0.1",
    "@streamdown/math": "^1.0.1",
    "@streamdown/mermaid": "^1.0.1",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.77",
    "better-auth": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "i18next": "^25.8.4",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "katex": "^0.16.28",
    "lucide-react": "^0.460.0",
    "pptx-preview": "^1.0.7",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^4.6.4",
    "react-router-dom": "^7.0.2",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "^3.7.0",
    "shiki": "3.22.0",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^2.5.5",
    "use-stick-to-bottom": "^1.1.3",
    "ws": "^8.19.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@lobehub/lint": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^22.9.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^28.0.0",
    "oxfmt": "0.28.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.5",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tar": "^7.5.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
